<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/audio_overlay_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:visibility="gone"
    tools:visibility="visible">

    <!-- Floating "review" target, sits above the bar (slide up / right to reach it). -->
    <LinearLayout
        android:id="@+id/expand_target"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="4dp"
        android:layout_marginTop="8dp"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/expand_circle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_audio_zone_circle"
            android:backgroundTint="?attr/colorSurfaceContainerHighest"
            android:elevation="4dp">

            <ImageView
                android:id="@+id/expand_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@string/audio_recording_slide_review"
                android:src="@drawable/baseline_open_in_full_24"
                app:tint="?attr/colorOnSurface" />
        </FrameLayout>

        <TextView
            android:id="@+id/expand_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/audio_recording_review_short"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Guidance line. -->
    <TextView
        android:id="@+id/hint_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:text="@string/audio_recording_gesture_hint"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="12sp" />

    <!-- Recording bar, sits over the message input. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/background_rounded_24"
        android:backgroundTint="?attr/colorSurfaceContainer"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:minHeight="48dp"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <!-- Cancel target (slide left to reach it). -->
        <FrameLayout
            android:id="@+id/cancel_target"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_audio_zone_circle"
            android:backgroundTint="?attr/colorSurfaceContainerHighest">

            <ImageView
                android:id="@+id/cancel_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:contentDescription="@string/audio_recording_slide_cancel"
                android:src="@drawable/baseline_delete_24"
                app:tint="@color/red_300" />
        </FrameLayout>

        <ImageView
            android:id="@+id/rec_dot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginStart="10dp"
            android:contentDescription="@null"
            android:src="@drawable/baseline_circle_24"
            app:tint="@color/red_500" />

        <TextView
            android:id="@+id/timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="monospace"
            android:text="00:00"
            android:textColor="?attr/colorOnSurface"
            android:textSize="15sp"
            tools:text="00:07" />

        <cx.ring.views.WaveformView
            android:id="@+id/waveform"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="4dp"
            android:contentDescription="@null"
            android:src="@drawable/baseline_mic_24"
            app:tint="@color/red_500" />
    </LinearLayout>

</LinearLayout>
